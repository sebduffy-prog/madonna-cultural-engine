# ── Brave Search API ──
# Sign up: https://api.search.brave.com/register (Free: 2,000 queries/month)
BRAVE_API_KEY=your_brave_api_key_here

# ── Spotify Web API ──
# Create app: https://developer.spotify.com/dashboard → Create App
# Set redirect URI to http://localhost:3000 (not used but required)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# ── Anthropic API (for AI-generated recommendations) ──
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Vercel KV (auto-populated when you connect KV in Vercel dashboard) ──
# Enable: Vercel Dashboard → Storage → Create KV Database → Connect to project
# These are automatically set by Vercel when KV is connected:
# KV_REST_API_URL=auto
# KV_REST_API_TOKEN=auto
