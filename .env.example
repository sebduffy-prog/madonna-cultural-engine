# Madonna Cultural Engine — environment variables
# Copy this file to .env.local and populate values.
# Also add each variable to the Vercel project (Settings → Environment Variables).

# ── Brave Search API (free tier: 2,000 queries/month) ──
# https://api.search.brave.com/register
BRAVE_API_KEY=

# ── Spotify Web API ──
# https://developer.spotify.com/dashboard → Create App (set redirect URI to http://localhost:3000)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── Anthropic API (AI-generated recommendations) ──
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── YouTube Data API v3 ──
# https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# ── Brand24 Data API ──
# https://app.brand24.com/account/integrations-api-data
BRAND24_API_KEY=
BRAND24_PROJECT_ID=
BRAND24_ACCOUNT_ID=

# ── Last.fm API ──
# https://www.last.fm/api/account/create
LASTFM_API_KEY=

# ── Vercel Blob (auto-populated when you enable Blob storage in the Vercel dashboard) ──
# BLOB_READ_WRITE_TOKEN=auto

# ── Vercel KV (auto-populated if KV is connected) ──
# KV_REST_API_URL=auto
# KV_REST_API_TOKEN=auto

# ── No key required ──
# GDELT, Apple Music RSS, Wikipedia Pageviews, Google Trends
